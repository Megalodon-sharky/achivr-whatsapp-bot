# --- Wati (WhatsApp BSP) ---
# Base API URL from Wati dashboard > API Docs (no trailing slash).
# e.g. https://live-mt-server.wati.io/123456   (older accounts: https://app-server.wati.io)
WATI_API_ENDPOINT=https://live-mt-server.wati.io/your-tenant-id
# Bearer access token from Wati dashboard > API Docs.
WATI_ACCESS_TOKEN=eyJ...
# A long random string YOU invent. Append it to the webhook URL as ?token=... in Wati,
# so we can authenticate inbound calls (Wati does not sign its webhooks).
WATI_WEBHOOK_SECRET=pick-any-long-random-string
# Optional: operator email to auto-assign escalated chats to. Blank = leave unassigned
# for Wati's own auto-routing.
WATI_AGENT_EMAIL=
# Optional: name of the APPROVED WhatsApp template that renders product recommendations as
# cards (image header + body + "View product" URL button). Blank = fall back to a plain
# image+caption message (no approval needed). See README "Product card template".
WATI_PRODUCT_TEMPLATE=

# --- Claude ---
ANTHROPIC_API_KEY=enter_api_key
# claude-sonnet-4-6 = balanced (default). claude-haiku-4-5-20251001 = cheaper/faster.
CLAUDE_MODEL=claude-sonnet-5

# --- Shopify (Admin GraphQL, custom app token) ---
# true = run on canned mock data (no store needed). Set false once Shopify is wired.
USE_MOCK_SHOPIFY=true
SHOPIFY_STORE_DOMAIN=achivr.myshopify.com
# Custom app Admin API access token (shpat_...) with read_orders + read_products scopes.
SHOPIFY_ADMIN_TOKEN=shpat_...
SHOPIFY_API_VERSION=2025-01
# Public storefront base, used to build product links when onlineStoreUrl is absent.
SHOPIFY_STOREFRONT_BASE=https://achivr.in

# --- Server ---
PORT=3000
